# Database Connection String (Session pooler — for runtime queries)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Direct connection to Supabase (Session pooler — for Prisma migrations)
DIRECT_URL="postgresql://user:password@host:port/dbname"

# The port the Node server will run on
PORT=3001

# The URL of your React frontend
CLIENT_URL="http://localhost:5173"

# Secret Key for JWT Authentication tokens
JWT_SECRET="your_jwt_secret_here"
